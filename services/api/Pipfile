[[source]]
name = "pypi"
url = "https://pypi.org/simple"
verify_ssl = true

[packages]
fastapi = "==0.116.1"
uvicorn = "==0.35.0"
python-multipart = "==0.0.20"
tinydb = "==4.8.2"
python-jose = {version = "==3.5.0", extras = ["cryptography"]}
passlib = {version = "==1.7.4", extras = ["bcrypt"]}
bcrypt = "==4.0.1"
email-validator = "==2.3.0"

[dev-packages]
httpx = "==0.28.1"
pytest = "==8.4.1"

[requires]
python_version = "c"

[scripts]
dev = "uvicorn trackflow_api.main:app --reload --host 0.0.0.0 --port 8000"
start = "uvicorn trackflow_api.main:app --host 0.0.0.0 --port 8000"
seed = "python -m trackflow_api.seed"
suppliers-seed = "python -m trackflow_api.seed"